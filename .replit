modules = ["nodejs-20", "web", "bash"]

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[env]
DEV_MODE = "true"
ENVIRONMENT = "dev"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Dev Server"

[[workflows.workflow]]
name = "Start Dev Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bun run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Setup"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bun install && bun run db:migrate:local"

[[workflows.workflow]]
name = "Clone Templates"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git clone --depth 1 https://github.com/cloudflare/vibesdk-templates.git .local-templates 2>/dev/null || (cd .local-templates && git pull)"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 4200

[[ports]]
localPort = 8787
externalPort = 3000
exposeLocalhost = true

[[ports]]
localPort = 8976
externalPort = 3001
