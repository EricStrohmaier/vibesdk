{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "shared/*": ["./shared/*"],
      "worker/*": ["./worker/*"]
    },
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "types": ["@cloudflare/workers-types", "./worker-configuration.d.ts"]
  },
  "include": ["./worker/**/*", "./shared/**/*", "./worker-configuration.d.ts"]
}
